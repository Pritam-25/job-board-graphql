    "typescript-eslint": "^8.55.0"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@t3-oss/env-core": "^0.13.10",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
